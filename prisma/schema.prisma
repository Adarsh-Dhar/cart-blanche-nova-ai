generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql" // Recommended for production e-commerce
  url      = env("DATABASE_URL")
}

model Vendor {
  id          String    @id @default(cuid())
  name        String
  description String?
  logoUrl     String?
  
  // Crypto Payment Fields
  pubkey      String    @unique // The wallet address for receiving x402/crypto payments
  
  // Relations
  products    Product[]
  orders      OrderItem[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([pubkey])
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  products  Product[]
  
  // To handle nested categories like "Groceries > Snacks"
  parentId  String?
  parent    Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children  Category[] @relation("SubCategories")
}

model Product {
  id            String   @id @default(cuid())
  productID     String   @unique // The ID from your JSON (e.g., BISC-001)
  sku           String   @unique
  gtin          String?  @unique
  mpn           String?
  name          String
  description   String
  images        String[] // Array of image URLs
  
  // Pricing
  price         Decimal  @db.Decimal(10, 2)
  currency      String   @default("USD")
  
  // Inventory
  stockQuantity Int      @default(0)
  availability  String   @default("https://schema.org/InStock")
  condition     String   @default("https://schema.org/NewCondition")

  // Relations
  vendorId      String
  vendor        Vendor   @relation(fields: [vendorId], references: [id])
  
  categoryId    String
  category      Category @relation(fields: [categoryId], references: [id])
  
  orderItems    OrderItem[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([vendorId])
  @@index([categoryId])
}

model Order {
  id              String        @id @default(cuid())
  totalAmount     Decimal       @db.Decimal(10, 2)
  status          OrderStatus   @default(PENDING)
  
  // Crypto Transaction Data
  txHash          String?       @unique // Transaction hash on the blockchain
  userWallet      String?       // Wallet address of the buyer
  
  items           OrderItem[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  quantity  Int
  price     Decimal @db.Decimal(10, 2) // Price at the time of purchase

  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  
  productId String
  product   Product @relation(fields: [productId], references: [id])
  
  vendorId  String
  vendor    Vendor  @relation(fields: [vendorId], references: [id])
}

enum OrderStatus {
  PENDING
  PROCESSING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}